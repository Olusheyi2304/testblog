{
  "name": "jollof",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:studio\" \"npm run dev:web\"",
    "dev:studio": "sanity dev",
    "dev:web": "npm run dev --prefix web",
    "build:studio": "sanity build",
    "build:web": "npm run build --prefix web",
    "install:web": "npm install --prefix web",
    "deploy": "sanity deploy"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/vision": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.22.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "concurrently": "^9.2.1",
    "eslint": "^9.28",
    "prettier": "^3.5",
    "typescript": "^5.8"
  },
  "prettier": {
    "bracketSpacing": false,
    "printWidth": 100,
    "semi": false,
    "singleQuote": true
  }
}